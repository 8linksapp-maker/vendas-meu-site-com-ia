---
// pages/index.astro
// Página de vendas principal do curso "Meu Site Com IA"
// Lê o conteúdo de src/data/content.json e renderiza todas as seções.
import { readFileSync } from 'fs';
import { join } from 'path';
import PageLayout from '../layouts/PageLayout.astro';
import UrgencyBar from '../components/sections/UrgencyBar.astro';
import Hero from '../components/sections/Hero.astro';
import Story from '../components/sections/Story.astro';
import WhoIsFor from '../components/sections/WhoIsFor.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import ValueStack from '../components/sections/ValueStack.astro';
import Comparison from '../components/sections/Comparison.astro';
import Pricing from '../components/sections/Pricing.astro';
import Guarantee from '../components/sections/Guarantee.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';

const raw = readFileSync(join(process.cwd(), 'src/data/content.json'), 'utf-8');
const c = JSON.parse(raw);
---
<PageLayout>
  <UrgencyBar text={c.urgency.text} active={c.urgency.active} />

  <Hero
    badge={c.hero.badge}
    headline={c.hero.headline}
    subheadline={c.hero.subheadline}
    stats={c.hero.stats}
  />

  <div class="section-divider"></div>

  <Story image={c.story.image} title={c.story.title} paragraphs={c.story.paragraphs} credentials={c.story.credentials} />

  <div class="section-divider"></div>

  <WhoIsFor items={c.whoIsFor} />

  <div class="section-divider"></div>

  <Testimonials items={c.testimonials} />

  <div class="section-divider"></div>

  <ValueStack
    base={c.valueStack}
    pro={c.valueStackPro}
    linkBase={c.pricing.base.link}
    linkPro={c.pricing.pro.link}
  />

  <div class="section-divider"></div>

  <Comparison rows={c.comparison} />

  <div class="section-divider"></div>

  <Pricing base={c.pricing.base} pro={c.pricing.pro} />

  <div class="section-divider"></div>

  <Guarantee />

  <div class="section-divider"></div>

  <FAQ items={c.faq} />

  <div class="section-divider"></div>

  <FinalCTA linkBase={c.pricing.base.link} linkPro={c.pricing.pro.link} />

  <!-- Footer mínimo -->
  <footer class="text-center py-8 text-sm" style="color: #6B7280; border-top: 1px solid #1E1E2E;">
    © 2026 Bruno Medeiros · Meu Site Com IA · Todos os direitos reservados
  </footer>
</PageLayout>
