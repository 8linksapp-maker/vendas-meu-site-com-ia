---
// pages/admin/hero.astro
// Painel admin: edição do hero (headline, subheadline, badge) e stats.
import { readFileSync } from 'fs';
import { join } from 'path';
import AdminLayout from '../../layouts/AdminLayout.astro';
import Field from '../../components/admin/Field.astro';
import { SESSION_COOKIE, verifyToken } from '../../utils/auth';

const token = Astro.cookies.get(SESSION_COOKIE)?.value || '';
if (!(await verifyToken(token))) return Astro.redirect('/admin/login');

const raw = readFileSync(join(process.cwd(), 'src/data/content.json'), 'utf-8');
const c = JSON.parse(raw);
const saved = Astro.url.searchParams.get('saved') === '1';
---
<AdminLayout title="Hero & Stats — Admin">
  <h1>✦ Hero &amp; Stats</h1>
  {saved && <div class="success">Alterações salvas com sucesso.</div>}

  <form id="hero-form">
    <div class="card">
      <h2>Topo da página</h2>
      <Field label="Badge" hint="Pequena tag acima do headline principal">
        <input type="text" name="badge" value={c.hero.badge} />
      </Field>
      <Field label="Headline principal" hint="Texto grande em destaque — use até 10 palavras">
        <textarea name="headline" rows={3}>{c.hero.headline}</textarea>
      </Field>
      <Field label="Subheadline" hint="Complemento da headline — 1 ou 2 linhas">
        <textarea name="subheadline" rows={3}>{c.hero.subheadline}</textarea>
      </Field>
    </div>

    <div class="card">
      <h2>Números / Estatísticas</h2>
      <p class="field-hint" style="margin-bottom:16px;">Exibidos abaixo do botão principal.</p>
      {c.hero.stats.map((s: any, i: number) => (
        <div class="two-col" style="margin-bottom:10px;">
          <Field label={i === 0 ? 'Valor' : ''}>
            <input type="text" name={`stat_val_${i}`} value={s.value} placeholder="20+" />
          </Field>
          <Field label={i === 0 ? 'Label' : ''}>
            <input type="text" name={`stat_label_${i}`} value={s.label} placeholder="Anos em web" />
          </Field>
        </div>
      ))}
      <input type="hidden" name="stats_count" value={c.hero.stats.length} />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn" id="save-btn">Salvar</button>
    </div>
  </form>

  <script>
    const form = document.getElementById('hero-form') as HTMLFormElement;
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.textContent = 'Salvando...'; btn.disabled = true;
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/admin/save-hero', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) window.location.href = '/admin/hero?saved=1';
      else { btn.textContent = 'Salvar'; btn.disabled = false; alert('Erro ao salvar.'); }
    });
  </script>
</AdminLayout>
