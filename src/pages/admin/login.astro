---
// pages/admin/login.astro
// Tela de login do painel admin.
// POST via fetch para /api/admin/login — redireciona ao admin se correto.
if (Astro.request.method === 'POST') {
  return Astro.redirect('/admin');
}
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — Admin Vendas</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #07070F;
      color: #F1F1FF;
      font-family: 'Inter', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      overflow: hidden;
    }

    /* Background grid sutil */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(99,102,241,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99,102,241,0.03) 1px, transparent 1px);
      background-size: 52px 52px;
      pointer-events: none;
    }

    /* Glow orb */
    body::after {
      content: '';
      position: fixed;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(99,102,241,0.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .wrapper {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 400px;
      padding: 24px;
    }

    /* Logo mark */
    .logo-mark {
      width: 52px; height: 52px;
      border-radius: 14px;
      background: linear-gradient(135deg, #6366F1, #818CF8);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      margin-bottom: 20px;
      box-shadow: 0 0 40px rgba(99,102,241,0.4), 0 4px 20px rgba(0,0,0,0.5);
    }

    .logo-title {
      font-family: 'Sora', sans-serif;
      font-weight: 800;
      font-size: 22px;
      color: #F1F1FF;
      margin-bottom: 6px;
      text-align: center;
    }

    .logo-sub {
      font-size: 13px;
      color: #6B6B88;
      margin-bottom: 36px;
      text-align: center;
    }

    .card {
      width: 100%;
      background: #0F0F1A;
      border: 1px solid #1E1E32;
      border-radius: 18px;
      padding: 36px 32px;
      position: relative;
      overflow: hidden;
    }

    /* linha de brilho no topo do card */
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(99,102,241,0.5), transparent);
    }

    label {
      display: block;
      font-size: 11.5px;
      font-weight: 700;
      color: #C4C4D4;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }

    input {
      width: 100%;
      padding: 11px 15px;
      background: #07070F;
      border: 1px solid #2A2A40;
      border-radius: 10px;
      color: #F1F1FF;
      font-size: 14.5px;
      font-family: 'Inter', sans-serif;
      transition: border-color 0.15s, box-shadow 0.15s;
      margin-bottom: 20px;
    }

    input:focus {
      outline: none;
      border-color: #6366F1;
      box-shadow: 0 0 0 3px rgba(99,102,241,0.14);
    }

    input::placeholder { color: #6B6B88; }

    button {
      width: 100%;
      padding: 13px;
      background: linear-gradient(135deg, #6366F1, #818CF8);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      box-shadow: 0 6px 24px rgba(99,102,241,0.3);
    }

    button:hover { opacity: 0.9; transform: translateY(-1px); }
    button:active { transform: translateY(0); opacity: 1; }

    .error-msg {
      display: none;
      align-items: center;
      gap: 8px;
      background: rgba(239,68,68,0.09);
      border: 1px solid rgba(239,68,68,0.25);
      color: #FCA5A5;
      padding: 10px 14px;
      border-radius: 9px;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 16px;
    }

    .error-msg.visible { display: flex; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="logo-mark">⚡</div>
    <p class="logo-title">Admin Vendas</p>
    <p class="logo-sub">Painel de controle — Meu Site Com IA</p>

    <div class="card">
      <div id="error-msg" class="error-msg">
        <span>✕</span> Senha incorreta. Tente novamente.
      </div>
      <label for="password">Senha de acesso</label>
      <input type="password" id="password" placeholder="••••••••••••" autofocus />
      <button id="login-btn">Entrar no painel</button>
    </div>
  </div>

  <script>
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const input = document.getElementById('password') as HTMLInputElement;
    const errEl = document.getElementById('error-msg')!;

    async function doLogin() {
      btn.textContent = 'Verificando...';
      btn.disabled = true;
      errEl.classList.remove('visible');

      const res = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: input.value }),
      });

      if (res.ok) {
        btn.textContent = '✓ Redirecionando...';
        window.location.href = '/admin';
      } else {
        btn.textContent = 'Entrar no painel';
        btn.disabled = false;
        errEl.classList.add('visible');
        input.select();
      }
    }

    btn.addEventListener('click', doLogin);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLogin(); });
  </script>
</body>
</html>
