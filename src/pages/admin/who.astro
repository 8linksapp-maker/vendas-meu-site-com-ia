---
// pages/admin/who.astro
// Painel admin: edição da seção "Para Quem É" — avatares com ícone, título e descrição.
import { readFileSync } from 'fs';
import { join } from 'path';
import AdminLayout from '../../layouts/AdminLayout.astro';
import Field from '../../components/admin/Field.astro';
import { SESSION_COOKIE, verifyToken } from '../../utils/auth';

const token = Astro.cookies.get(SESSION_COOKIE)?.value || '';
if (!(await verifyToken(token))) return Astro.redirect('/admin/login');

const raw = readFileSync(join(process.cwd(), 'src/data/content.json'), 'utf-8');
const c = JSON.parse(raw);
const saved = Astro.url.searchParams.get('saved') === '1';
---
<AdminLayout title="Para Quem É — Admin">
  <h1>◇ Para Quem É</h1>
  {saved && <div class="success">Alterações salvas com sucesso.</div>}

  <form id="who-form">
    {c.whoIsFor.map((item: any, i: number) => (
      <div class="card">
        <div class="card-num">
          <span class="num-badge">{i + 1}</span>
          <h2>Avatar</h2>
        </div>
        <div class="two-col">
          <Field label="Emoji / Ícone">
            <input type="text" name={`icon_${i}`} value={item.icon} style="font-size:24px;" />
          </Field>
          <Field label="Título">
            <input type="text" name={`title_${i}`} value={item.title} />
          </Field>
        </div>
        <Field label="Descrição">
          <textarea name={`desc_${i}`} rows={2}>{item.description}</textarea>
        </Field>
      </div>
    ))}
    <input type="hidden" name="count" value={c.whoIsFor.length} />
    <div class="form-actions">
      <button type="submit" class="btn" id="save-btn">Salvar</button>
    </div>
  </form>

  <script>
    const form = document.getElementById('who-form') as HTMLFormElement;
    const btn = document.getElementById('save-btn') as HTMLButtonElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.textContent = 'Salvando...'; btn.disabled = true;
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/admin/save-who', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (res.ok) window.location.href = '/admin/who?saved=1';
      else { btn.textContent = 'Salvar'; btn.disabled = false; alert('Erro ao salvar.'); }
    });
  </script>
</AdminLayout>
