---
// sections/ValueStack.astro
// Seção de stack de valor com ancoragem de preço.
// Mobile: tag quebra para nova linha, preço empilhado verticalmente.
interface Props {
  base: { item: string; from: string; tag: string }[];
  pro:  { item: string; from: string; tag: string }[];
  linkBase: string;
  linkPro: string;
}
const { base, pro, linkBase, linkPro } = Astro.props;

const totalBase = 'R$10.194';
const totalPro  = 'R$13.191';
---
<section class="py-24 px-4 sm:px-6" style="background: #111118;">
  <div class="max-w-3xl mx-auto">

    <div class="text-center mb-16">
      <div class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6"
        style="background: rgba(99,102,241,0.1); color: #818CF8;">
        O que você leva
      </div>
      <h2 class="font-heading font-bold text-3xl md:text-4xl gradient-text">Tudo que está incluso</h2>
    </div>

    <!-- Plano Base -->
    <div class="rounded-2xl overflow-hidden mb-8" style="border: 1px solid #1E1E2E;">
      <div class="px-5 py-4" style="background: rgba(99,102,241,0.08); border-bottom: 1px solid #1E1E2E;">
        <span class="font-heading font-bold text-lg">Plano Base</span>
      </div>
      <div>
        {base.map(row => (
          <div class="flex items-start justify-between gap-3 px-5 py-4" style="border-bottom: 1px solid #1E1E2E;">
            <div class="flex items-start gap-2.5 min-w-0">
              <span class="mt-0.5 shrink-0 text-xs" style={row.tag === 'bônus' ? "color: #10B981;" : "color: #6366F1;"}>✓</span>
              <span class="text-sm leading-snug" style="color: rgba(255,255,255,0.85);">{row.item}</span>
            </div>
            <div class="flex flex-col items-end shrink-0 gap-1 ml-2">
              {row.from && <span class="text-xs line-through whitespace-nowrap" style="color: #6B7280;">{row.from}</span>}
              <span class="text-xs font-bold px-2 py-1 rounded-full whitespace-nowrap"
                style={row.tag === 'bônus'
                  ? "background: rgba(16,185,129,0.12); color: #6EE7B7; border: 1px solid rgba(16,185,129,0.25);"
                  : "background: rgba(99,102,241,0.15); color: #A5B4FC;"}>
                {row.tag}
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 px-5 py-5" style="background: #080810; border-top: 1px solid #1E1E2E;">
        <div>
          <p class="text-xs" style="color: #6B7280;">Valor total dos itens</p>
          <p class="font-heading font-bold text-lg line-through" style="color: #6B7280;">{totalBase}</p>
        </div>
        <div class="sm:text-right">
          <p class="text-xs mb-1" style="color: #6B7280;">Você investe</p>
          <p class="font-heading font-extrabold text-2xl gradient-text-indigo leading-tight">12x R$51,40</p>
          <p class="text-xs mt-0.5" style="color: rgba(255,255,255,0.35);">ou R$497 à vista</p>
        </div>
      </div>
      <div class="px-5 pb-5" style="background: #080810;">
        <a href={linkBase}
          class="block text-center font-heading font-bold py-4 rounded-xl text-white"
          style="background: linear-gradient(135deg, #6366F1, #818CF8); box-shadow: 0 8px 24px rgba(99,102,241,0.3); min-height: 52px; display: flex; align-items: center; justify-content: center;">
          Quero investir — Plano Base
        </a>
      </div>
    </div>

    <!-- Plano Pro -->
    <div class="rounded-2xl overflow-hidden" style="border: 1px solid rgba(99,102,241,0.4); box-shadow: 0 0 40px rgba(99,102,241,0.08);">
      <div class="px-5 py-4 flex items-center justify-between"
        style="background: rgba(99,102,241,0.15); border-bottom: 1px solid rgba(99,102,241,0.3);">
        <span class="font-heading font-bold text-lg">Plano Pro</span>
        <span class="text-xs font-bold px-3 py-1 rounded-full shrink-0 ml-2"
          style="background: #6366F1; color: #fff;">Mais completo</span>
      </div>
      <div>
        {[...base, ...pro].map((row, i) => (
          <div class="flex items-start justify-between gap-3 px-5 py-4" style="border-bottom: 1px solid #1E1E2E;">
            <div class="flex items-start gap-2.5 min-w-0">
              <span class="mt-0.5 shrink-0 text-xs" style={row.tag === 'bônus' ? "color: #10B981;" : "color: #6366F1;"}>✓</span>
              <span class="text-sm leading-snug"
                style={i >= base.length ? "color: #A5B4FC; font-weight: 600;" : "color: rgba(255,255,255,0.85);"}>
                {row.item}
              </span>
            </div>
            <div class="flex flex-col items-end shrink-0 gap-1 ml-2">
              {row.from && <span class="text-xs line-through whitespace-nowrap" style="color: #6B7280;">{row.from}</span>}
              <span class="text-xs font-bold px-2 py-1 rounded-full whitespace-nowrap"
                style={row.tag === 'bônus'
                  ? "background: rgba(16,185,129,0.12); color: #6EE7B7; border: 1px solid rgba(16,185,129,0.25);"
                  : i >= base.length
                    ? "background: rgba(99,102,241,0.3); color: #A5B4FC;"
                    : "background: rgba(99,102,241,0.15); color: #A5B4FC;"}>
                {row.tag}
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 px-5 py-5" style="background: #080810; border-top: 1px solid #1E1E2E;">
        <div>
          <p class="text-xs" style="color: #6B7280;">Valor total dos itens</p>
          <p class="font-heading font-bold text-lg line-through" style="color: #6B7280;">{totalPro}</p>
        </div>
        <div class="sm:text-right">
          <p class="text-xs mb-1" style="color: #6B7280;">Você investe</p>
          <p class="font-heading font-extrabold text-2xl gradient-text-indigo leading-tight">12x R$103,11</p>
          <p class="text-xs mt-0.5" style="color: rgba(255,255,255,0.35);">ou R$997 à vista</p>
        </div>
      </div>
      <div class="px-5 pb-5" style="background: #080810;">
        <a href={linkPro}
          class="block text-center font-heading font-bold py-4 rounded-xl text-white"
          style="background: linear-gradient(135deg, #4F46E5, #6366F1); box-shadow: 0 8px 24px rgba(99,102,241,0.4); min-height: 52px; display: flex; align-items: center; justify-content: center;">
          Quero investir — Plano Pro
        </a>
      </div>
    </div>

  </div>
</section>
