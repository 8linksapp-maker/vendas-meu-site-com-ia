---
// sections/Pricing.astro
// Seção de preços — dois planos com parcelas em destaque.
interface Props {
  base: { name: string; price: string; priceTotal: string; period: string; description: string; items: string[]; cta: string; link: string };
  pro:  { name: string; price: string; priceTotal: string; period: string; description: string; badge?: string; items: string[]; cta: string; link: string };
}
const { base, pro } = Astro.props;
---
<section id="pricing" class="py-24 px-6" style="background: #111118;">
  <div class="max-w-3xl mx-auto">

    <div class="text-center mb-16">
      <div class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6"
        style="background: rgba(99,102,241,0.1); color: #818CF8;">
        Escolha seu plano
      </div>
      <h2 class="font-heading font-bold text-3xl md:text-4xl gradient-text">
        Invista uma vez. Colha para sempre.
      </h2>
      <p class="mt-4" style="color: #6B7280;">Acesso por 12 meses ao curso. Site no ar para sempre.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start max-w-2xl mx-auto">

      <!-- Plano Base -->
      <div class="rounded-2xl p-8" style="background: #080810; border: 1px solid #1E1E2E;">
        <p class="font-heading font-bold text-lg mb-1">{base.name}</p>
        <p class="text-sm mb-7" style="color: #6B7280;">{base.description}</p>

        <!-- Preço principal: parcela em destaque -->
        <div class="mb-1">
          <span class="font-heading font-extrabold" style="font-size: 2.4rem; line-height: 1;">{base.price}</span>
        </div>
        <p class="text-sm mb-1" style="color: #6B7280;">{base.period}</p>
        <p class="text-sm font-semibold mb-7" style="color: rgba(255,255,255,0.5);">{base.priceTotal}</p>

        <ul class="space-y-3 mb-8">
          {base.items.map(item => (
            <li class="flex items-start gap-3 text-sm" style="color: rgba(255,255,255,0.75);">
              <span class="mt-0.5 shrink-0" style="color: #6366F1;">✓</span>
              {item}
            </li>
          ))}
        </ul>

        <a href={base.link}
          class="block text-center font-heading font-bold py-4 rounded-xl transition-all hover:scale-[1.02]"
          style="background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.4); color: #A5B4FC;">
          {base.cta}
        </a>
      </div>

      <!-- Plano Pro -->
      <div class="rounded-2xl p-8 relative"
        style="background: #080810; border: 1px solid rgba(99,102,241,0.5); box-shadow: 0 0 40px rgba(99,102,241,0.1);">

        {pro.badge && (
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-xs font-bold text-white"
            style="background: linear-gradient(135deg, #6366F1, #818CF8); white-space: nowrap;">
            {pro.badge}
          </div>
        )}

        <p class="font-heading font-bold text-lg mb-1">{pro.name}</p>
        <p class="text-sm mb-7" style="color: #6B7280;">{pro.description}</p>

        <!-- Preço principal: parcela em destaque -->
        <div class="mb-1">
          <span class="font-heading font-extrabold gradient-text-indigo" style="font-size: 2.4rem; line-height: 1;">{pro.price}</span>
        </div>
        <p class="text-sm mb-1" style="color: #6B7280;">{pro.period}</p>
        <p class="text-sm font-semibold mb-7" style="color: rgba(255,255,255,0.5);">{pro.priceTotal}</p>

        <ul class="space-y-3 mb-8">
          {pro.items.map((item, i) => (
            <li class="flex items-start gap-3 text-sm"
              style={i === 0 ? "color: #A5B4FC; font-weight: 600;" : "color: rgba(255,255,255,0.75);"}>
              <span class="mt-0.5 shrink-0" style="color: #6366F1;">✓</span>
              {item}
            </li>
          ))}
        </ul>

        <a href={pro.link}
          class="block text-center font-heading font-bold py-4 rounded-xl text-white transition-all hover:scale-[1.02]"
          style="background: linear-gradient(135deg, #6366F1, #818CF8); box-shadow: 0 8px 24px rgba(99,102,241,0.3);">
          {pro.cta}
        </a>
      </div>
    </div>

    <!-- Ancoragem -->
    <p class="text-center mt-10 text-sm" style="color: #6B7280;">
      R$497 à vista ÷ 365 dias = <strong style="color: #A5B4FC;">R$1,36 por dia.</strong> Menos que um café.
    </p>
  </div>
</section>
