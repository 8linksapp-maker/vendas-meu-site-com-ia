---
// sections/Story.astro
// Seção de narrativa (Epiphany Bridge) em 2 colunas: texto + foto.
interface Props {
  image: string;
  title: string;
  paragraphs: string[];
  credentials: { icon: string; text: string }[];
}
const { image, title, paragraphs, credentials } = Astro.props;
---
<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Coluna de texto -->
      <div>
        <div class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6"
          style="background: rgba(99,102,241,0.1); color: #818CF8;">
          A história
        </div>

        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-10 gradient-text leading-tight">{title}</h2>

        <div class="space-y-5">
          {paragraphs.map((p, i) => (
            <p class="text-base leading-relaxed"
              style={i === paragraphs.length - 1
                ? "color: #fff; font-weight: 600; padding-left: 16px; border-left: 2px solid #6366F1;"
                : "color: rgba(255,255,255,0.72);"}>
              {p}
            </p>
          ))}
        </div>

        <!-- Credenciais -->
        <div class="mt-10 space-y-3">
          {credentials.map(c => (
            <div class="flex items-center gap-3 py-3 px-4 rounded-xl"
              style="background: rgba(255,255,255,0.03); border: 1px solid #1E1E2E;">
              <span class="text-xl">{c.icon}</span>
              <p class="text-sm" style="color: rgba(255,255,255,0.65);">{c.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Coluna da foto -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Glow atrás da foto -->
          <div class="absolute inset-0 rounded-3xl blur-3xl opacity-20 -z-10"
            style="background: radial-gradient(circle, #6366F1, #A5B4FC); transform: scale(1.1);"></div>

          <!-- Frame da foto -->
          <div class="relative rounded-2xl overflow-hidden"
            style="border: 1px solid rgba(99,102,241,0.25); box-shadow: 0 24px 60px rgba(0,0,0,0.5);">
            <img
              src={image}
              alt="Bruno Medeiros — especialista em SEO e criação de sites com IA"
              class="w-full max-w-sm object-cover"
              style="display: block; max-height: 520px; object-fit: cover; object-position: top;"
            />
            <!-- Overlay sutil no rodapé da foto -->
            <div class="absolute bottom-0 left-0 right-0 h-24"
              style="background: linear-gradient(to top, rgba(8,8,16,0.8), transparent);"></div>

            <!-- Badge sobre a foto -->
            <div class="absolute bottom-5 left-5 right-5">
              <div class="flex items-center gap-3 px-4 py-3 rounded-xl backdrop-blur-md"
                style="background: rgba(8,8,16,0.7); border: 1px solid rgba(99,102,241,0.3);">
                <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm shrink-0"
                  style="background: linear-gradient(135deg, #6366F1, #818CF8);">B</div>
                <div>
                  <p class="text-sm font-bold" style="color: #fff;">Bruno Medeiros</p>
                  <p class="text-xs" style="color: #A5B4FC;">SEO Expert · Web Creator</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
