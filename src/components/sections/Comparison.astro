---
// sections/Comparison.astro
// Tabela comparativa WordPress vs JAMstack/Meu Site Com IA.
interface Props { rows: { feature: string; wordpress: string; jamstack: string }[] }
const { rows } = Astro.props;
---
<section class="py-24 px-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <div class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6" style="background: rgba(239,68,68,0.1); color: #FCA5A5;">
        Comparativo
      </div>
      <h2 class="font-heading font-bold text-3xl md:text-4xl gradient-text">WordPress vs o novo padrão</h2>
      <p class="mt-4" style="color: #6B7280;">WordPress não é ruim. Só ficou para trás.</p>
    </div>

    <div class="rounded-2xl overflow-hidden" style="border: 1px solid #1E1E2E;">
      <!-- Header -->
      <div class="grid grid-cols-3 px-6 py-4" style="background: #111118; border-bottom: 1px solid #1E1E2E;">
        <div class="text-sm font-bold" style="color: #6B7280;">Critério</div>
        <div class="text-sm font-bold text-center" style="color: #EF4444;">WordPress</div>
        <div class="text-sm font-bold text-center gradient-text-indigo">Meu Site Com IA</div>
      </div>
      <!-- Rows -->
      {rows.map((row, i) => (
        <div class="grid grid-cols-3 px-6 py-4" style={`border-bottom: 1px solid #1E1E2E; background: ${i % 2 === 0 ? '#080810' : '#0C0C14'};`}>
          <div class="text-sm font-medium" style="color: rgba(255,255,255,0.7);">{row.feature}</div>
          <div class="text-sm text-center" style="color: rgba(239,68,68,0.8);">{row.wordpress}</div>
          <div class="text-sm text-center font-semibold" style="color: #A5B4FC;">{row.jamstack}</div>
        </div>
      ))}
    </div>
  </div>
</section>
