---
// sections/WhoIsFor.astro
// Seção de avatares — para quem é o curso.
interface Props { items: { icon: string; title: string; description: string }[] }
const { items } = Astro.props;
---
<section class="py-24 px-6" style="background: #111118;">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6" style="background: rgba(99,102,241,0.1); color: #818CF8;">
      Para quem é
    </div>
    <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 gradient-text">Esse curso foi feito para você se...</h2>
    <p class="mb-16" style="color: #6B7280;">Qualquer um que queira criar, entregar ou ranquear sites sem depender de dev.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {items.map(item => (
        <div class="p-8 rounded-2xl text-left transition-all hover:scale-[1.02]" style="background: #080810; border: 1px solid #1E1E2E;">
          <div class="text-4xl mb-5">{item.icon}</div>
          <h3 class="font-heading font-bold text-lg mb-3">{item.title}</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
